modules = ["nodejs-24", "python-3.11"]

[deployment]
router = "application"
deploymentTarget = "autoscale"

[deployment.postBuild]
args = ["pnpm", "store", "prune"]
env = { "CI" = "true" }

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "AI Agents Service"

[[workflows.workflow]]
name = "AI Agents Service"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "AGENTS_PORT=8001 python3 agents/main.py"
waitForPort = 8001

[workflows.workflow.metadata]
outputType = "console"

[agent]
stack = "PNPM_WORKSPACE"
expertMode = true

[postMerge]
path = "scripts/post-merge.sh"
timeoutMs = 20000

[[ports]]
localPort = 8001
externalPort = 3000

[[ports]]
localPort = 8080
externalPort = 8080

[[ports]]
localPort = 8081
externalPort = 80

[[ports]]
localPort = 23630
externalPort = 3002

[nix]
channel = "stable-25_05"
packages = ["libxcrypt"]

[userenv]

[userenv.shared]
AGENTS_SERVICE_URL = "http://localhost:8001"
